spring:
  data:
    mongodb:
      uri: mongodb://mongo:27017/competitions_db
      database: competitions_db
  rabbitmq:
    host: rabbitmq
    port: 5672
    username: ${RABBITMQ_USERNAME}
    password: ${RABBITMQ_PASSWORD}

eureka:
  client:
    service-url:
      defaultZone: http://eureka-server:8761/eureka/
